###############################################################################
# Docker Compose – infrastructure variables
# Copy to .env and adjust as needed: cp .env.example .env
###############################################################################

# Project name (used as prefix for containers, volumes, networks)
COMPOSE_PROJECT_NAME=notes

# Host UID/GID – keeps file ownership in sync between host and containers
HOST_UID=1000
HOST_GID=1000

# Exposed host ports
BACKEND_PORT=8880
FRONTEND_PORT=5173
DB_PORT=3307
PMA_PORT=8881

# MariaDB credentials (shared by db + phpmyadmin services)
DB_NAME=notes
DB_USER=app
DB_PASSWORD=app
DB_ROOT_PASSWORD=root
